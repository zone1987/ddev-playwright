# Force LF for shell scripts and generated text files so they work on Windows
# checkouts (a CRLF in a shebang line breaks `#!/usr/bin/env bash`).
* text=auto eol=lf
*.sh text eol=lf
commands/host/playwright text eol=lf
*.ts text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Exclude files from releases/tarballs
tests/ export-ignore
.github/ export-ignore
.gitattributes export-ignore
.editorconfig export-ignore
