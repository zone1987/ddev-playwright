#!/usr/bin/env bash
#ddev-generated

## Description: Run the Playwright CLI inside the isolated playwright container
## Usage: playwright [--ui] [<playwright-cli-args>...]
## Example: |-
##   ddev playwright test                        # run your tests (npx playwright test)
##   ddev playwright test tests/e2e/foo.spec.ts  # run a single spec
##   ddev playwright --ui                        # open the native UI mode in the browser
##   ddev playwright test --headed --grep smoke  # any Playwright CLI args pass straight through
##   ddev playwright codegen https://example.com # any Playwright CLI subcommand works
##   ddev playwright --version
## HostWorkingDir: true
## CanRunGlobally: false

# macOS bash 3.2 safe. POSIX-ish where possible.
set -u

APPROOT="${DDEV_APPROOT:-$(pwd)}"

# Ensure the project (and the playwright container) is running.
if [ "${DDEV_PROJECT_STATUS:-}" != "running" ]; then
  ddev start >/dev/null 2>&1 || true
fi

# Run the Playwright CLI in the container from the SAME directory you invoked the
# command in (HostWorkingDir maps it), so `npx playwright` resolves the config and
# node_modules from wherever you installed Playwright (project root or a subfolder
# like shopware/). Playwright + your tests are installed by YOU; this add-on only
# provides the container.
#
# Map the host CWD to its in-container path under /var/www/html. DDEV mounts the
# project root (the parent of .ddev) at /var/www/html.
host_cwd="$(pwd)"
rel="${host_cwd#"${APPROOT}"}"
rel="${rel#/}"
container_dir="/var/www/html${rel:+/$rel}"

pw() {
  # shellcheck disable=SC2086
  ddev exec -s playwright sh -c "cd '${container_dir}' 2>/dev/null || cd /var/www/html; npx --no-install playwright $*"
}

# --ui anywhere in the args switches to UI mode, bound to 0.0.0.0 so the DDEV
# router can expose it. Everything else is forwarded verbatim.
UI=0
ARGS=""
for a in "$@"; do
  case "$a" in
    --ui) UI=1 ;;
    *) ARGS="${ARGS} $a" ;;
  esac
done

if [ "${UI}" -eq 1 ]; then
  url="https://${DDEV_HOSTNAME:-$DDEV_SITENAME.ddev.site}:8078"
  echo "Opening Playwright UI mode at ${url}"
  # If no explicit subcommand was given, default to `test` (UI mode needs it).
  case "${ARGS}" in
    *test*) : ;;
    *) ARGS="test ${ARGS}" ;;
  esac
  # shellcheck disable=SC2086
  pw ${ARGS} --ui --ui-host=0.0.0.0 --ui-port=8077
  exit $?
fi

# No args → show usage rather than a bare Playwright help dump.
if [ -z "${ARGS# }" ]; then
  echo "Usage: ddev playwright [--ui] <playwright-cli-args>" >&2
  echo "  e.g. ddev playwright test | ddev playwright --ui | ddev playwright codegen <url>" >&2
  exit 1
fi

# shellcheck disable=SC2086
pw ${ARGS}
exit $?
